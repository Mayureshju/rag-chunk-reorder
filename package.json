{
  "name": "rag-chunk-reorder",
  "version": "0.1.7",
  "description": "RAG chunk reordering, retrieval reranking, and context packing to mitigate lost-in-the-middle in LLM context windows. Drop-in reordering for LangChain, LlamaIndex, Vercel AI, and any RAG pipeline.",
  "main": "dist/cjs/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./adapters": {
      "import": {
        "types": "./dist/esm/adapters.d.ts",
        "default": "./dist/esm/adapters.js"
      },
      "require": {
        "types": "./dist/cjs/adapters.d.ts",
        "default": "./dist/cjs/adapters.js"
      }
    },
    "./rerankers": {
      "import": {
        "types": "./dist/esm/rerankers.d.ts",
        "default": "./dist/esm/rerankers.js"
      },
      "require": {
        "types": "./dist/cjs/rerankers.d.ts",
        "default": "./dist/cjs/rerankers.js"
      }
    },
    "./pipelines": {
      "import": {
        "types": "./dist/esm/pipelines.d.ts",
        "default": "./dist/esm/pipelines.js"
      },
      "require": {
        "types": "./dist/cjs/pipelines.d.ts",
        "default": "./dist/cjs/pipelines.js"
      }
    },
    "./observability": {
      "import": {
        "types": "./dist/esm/observability.d.ts",
        "default": "./dist/esm/observability.js"
      },
      "require": {
        "types": "./dist/cjs/observability.d.ts",
        "default": "./dist/cjs/observability.js"
      }
    }
  },
  "bin": {
    "rag-chunk-reorder": "dist/cjs/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > dist/esm/package.json",
    "bench": "npm run build && node bench/run.js",
    "prepublishOnly": "npm run build && npm test",
    "test": "jest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "rag",
    "llm",
    "langchain",
    "llamaindex",
    "vercel-ai",
    "context-window",
    "op-rag",
    "cross-encoder",
    "mmr",
    "chunking",
    "retrieval",
    "rag-pipeline",
    "nextjs",
    "vector-search",
    "retrieval-augmented-generation",
    "retrieval-reranking",
    "reranking",
    "rerank",
    "context-packing",
    "llm-context",
    "context-reordering",
    "chunk-reordering",
    "lost-in-the-middle",
    "ranking",
    "reranker"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mayureshju/rag-chunk-reorder.git"
  },
  "bugs": {
    "url": "https://github.com/Mayureshju/rag-chunk-reorder/issues"
  },
  "homepage": "https://resonant-parfait-d49e6a.netlify.app",
  "sideEffects": false,
  "peerDependencies": {
    "@dqbd/tiktoken": "*",
    "tiktoken": "*"
  },
  "peerDependenciesMeta": {
    "@dqbd/tiktoken": {
      "optional": true
    },
    "tiktoken": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
